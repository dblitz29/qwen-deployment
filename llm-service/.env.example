# LLM Service Configuration

# Model path (inside container)
# Format: /models/<model-name>/model.gguf
# 
# For split GGUF files, entrypoint will auto-merge them first.
# After merge, the file will be: /models/<model-name>/model.gguf
#
# Examples:
# MODEL_PATH=/models/qwen2.5-7b-instruct/model.gguf
# MODEL_PATH=/models/qwen2.5-32b-instruct/model.gguf
# MODEL_PATH=/models/qwen3-7b-instruct/model.gguf

MODEL_PATH=/models/qwen2.5-7b-instruct/model.gguf
